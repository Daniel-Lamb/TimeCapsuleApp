# Copy to .env and fill in from your Supabase project settings (API section).
# Both values are safe to ship in the browser bundle; the anon key is
# powerless on its own because RLS denies it on every capsule table.
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key
